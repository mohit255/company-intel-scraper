# Copy to .env and fill in your values: cp .env.example .env
# Loaded automatically by run_scrape.sh. Not auto-loaded by the Python
# scripts themselves — db.py reads DATABASE_URL directly via os.environ,
# but company_scraper.py's tuning knobs are CLI flags only (see README).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:port/db_name

# ── Scraper tuning (used by run_scrape.sh -> scraper.py) ───────────────────────
SCRAPER_WORKERS=8          # concurrent worker tasks
SCRAPER_NEWS_LIMIT=15      # max news articles per company
SCRAPER_JOBS_LIMIT=15      # max job listings per company
SCRAPER_PRODUCTS_LIMIT=10  # max product/pricing pages per company
SCRAPER_DELAY=0.5          # min seconds between requests to the same domain
SCRAPER_TIMEOUT=30         # HTTP request timeout in seconds

# Companies file consumed by the scraper (relative to repo root)
COMPANIES_FILE=companies.json

# ── Proxy pool (used by run_scrape.sh -> scraper.py, optional) ─────────────────
# Leave PROXY_FILE unset (or point it at an empty/missing file) to run without
# proxies. When set, run_scrape.sh auto-refreshes via fetch_fresh_proxies.py
# if the pool drops below 50 entries.
PROXY_FILE=proxies.txt
PROXY_ROTATION=random       # random | round-robin
MAX_PROXY_FAILURES=3        # failures before a proxy is dropped from rotation

# ── company_scraper.py filters (CLI flags only, NOT read from this file —
#    listed here as a reference for the manual commands in the README) ────────
# --field AI       # only scrape companies in this field
# --only news      # only scrape one type: news | jobs | products | brand
